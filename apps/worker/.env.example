APP_REDIS_CONN_STRING=redis://127.0.0.1:6379
APP_BACKEND_GRPC_URL=127.0.0.1:50051
APP_INTERNAL_AUTH_TOKEN=secure_internal_token_for_communication


# Sandbox Limits & Controls
# Giới hạn số lượng sandbox chạy song song tối đa trên Worker này (tùy thuộc vào CPU/RAM của máy chủ chạy worker)
SANDBOX_MAX_CONCURRENT=8